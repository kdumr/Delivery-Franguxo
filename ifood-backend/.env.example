# ─── iFood Backend — Variáveis de Ambiente ───────────────────────────────────

# URL base do WordPress (sem barra final)
# Exemplo: https://franguxo.app.br
WP_BASE_URL=https://seusite.com.br

# Segredo compartilhado: backend → WordPress (header X-MyD-Secret)
# Deve ser igual ao campo "WP API Secret" nas configurações iFood do WordPress
WP_API_SECRET=coloque-um-segredo-forte-aqui

# Segredo compartilhado: WordPress → backend (POST /config)
# Deve ser igual ao campo "Backend Push Secret" nas configurações iFood do WordPress
BACKEND_SECRET=coloque-outro-segredo-forte-aqui

# Credenciais iFood (opcional se usar push via WordPress /config)
# Se definidos aqui, são usados como valor padrão antes de receber config do WP
IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=
IFOOD_MERCHANT_ID=

# Porta do servidor (padrão 3001 para não conflitar com o push server)
PORT=3001

# Habilitar HTTPS (true/false). Se false, roda em HTTP.
USE_HTTPS=false
