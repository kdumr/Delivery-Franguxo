# ── iFood Backend — Variáveis de Ambiente ──────────────────────────────────

# Porta do servidor (EasyPanel expõe 3000 por padrão)
PORT=3000

# Segredo compartilhado entre este backend e o WordPress
# O WordPress usa isso no header X-Backend-Secret ao fazer push de config
BACKEND_SECRET=troque-por-um-valor-secreto-aqui

# ── Credenciais iFood ───────────────────────────────────────────────────────
# Podem ser omitidas aqui e configuradas via painel WordPress
IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=
IFOOD_MERCHANT_ID=

# ── WordPress ───────────────────────────────────────────────────────────────
# URL base do WordPress (sem trailing slash)
WP_BASE_URL=https://seusite.com.br

# Segredo compartilhado — WordPress valida via X-WP-Secret
WP_API_SECRET=troque-por-outro-valor-secreto
