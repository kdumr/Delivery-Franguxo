{
  "name": "franguxo-gestor-pedidos",
  "version": "4.1.11",
  "description": "Franguxo Gestor de Pedidos",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "powershell -Command \"if (Test-Path 'dist/franguxo-gestor-win32-x64') { Remove-Item -Recurse -Force 'dist/franguxo-gestor-win32-x64' }\" && electron-packager . franguxo-gestor --platform=win32 --arch=x64 --out=dist/ --overwrite",
    "dist": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "keywords": [
    "electron",
    "franguxo",
    "pedidos"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^37.2.3",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "@niick555/node-printer": "^1.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "electron-updater": "^6.6.2",
    "express": "^4.18.2",
    "iconv-lite": "^0.6.3",
    "pngjs": "^7.0.0"
  },
  "build": {
    "appId": "br.com.franguxo.gestor",
    "productName": "Franguxo Gestor de Pedidos",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kdumr",
        "repo": "gestordepedidos",
        "releaseType": "release"
      }
    ],
    "files": [
      "**/*",
      "!dist/**",
      "!release/**",
      "!node_modules/.cache/**"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "server.js",
      "node_modules/**",
      "node_modules/@niick555/node-printer/**"
    ],
    "win": {
      "icon": "assets/img/franguxoicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Franguxo Gestor",
      "installerIcon": "assets/img/franguxoicon.ico",
      "uninstallerIcon": "assets/img/franguxoicon.ico",
      "installerHeaderIcon": "assets/img/franguxoicon.ico",
      "include": "installer.nsh"
    }
  }
}