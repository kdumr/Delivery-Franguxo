					mapPickerDetailsView.appendChild(detailsMiniMap);
					mapPickerDetailsView.appendChild(mapPickerDetailsAddress);
					mapPickerDetailsView.appendChild(detailsForm);
					mapPickerDetailsView.appendChild(detailsFooter);

					// Add both views to inner container
					mapPickerInner.appendChild(mapPickerMapView);
					mapPickerInner.appendChild(mapPickerDetailsView);
					mapPickerModal.appendChild(mapPickerInner);
					document.body.appendChild(mapPickerModal);

					// Back button handler
					mapPickerBackBtn.onclick = () => {
						mapPickerDetailsView.style.display = 'none';
						mapPickerMapView.style.display = 'block';
					};

					// Save button handler
					mapPickerSaveBtn.onclick = () => {
						if (mapPickerPendingResolve && mapPickerPendingData) {
							// Add extra fields to the pending data
							mapPickerPendingData.streetNumber = mapPickerDetailsNumber.value.trim();
							mapPickerPendingData.complement = mapPickerDetailsComplement.value.trim();
							mapPickerPendingData.reference = mapPickerDetailsReference.value.trim();
							
							// Close modal
							mapPickerModal.style.display = 'none';
							if (mapPickerDragOverlay && mapPickerDragOverlay.hide) mapPickerDragOverlay.hide();
							mapPickerDragState = null;
							if (mapPickerDragCardElement) mapPickerDragCardElement.style.cursor = 'grab';
							if (mapPickerInstance) {
								try { mapPickerInstance.setOptions({ draggable: true }); } catch (e) { }
							}
							
							// Reset views for next use
							mapPickerDetailsView.style.display = 'none';
							mapPickerMapView.style.display = 'block';
							
							// Resolve promise
							mapPickerPendingResolve(mapPickerPendingData);
							mapPickerPendingResolve = null;
							mapPickerPendingData = null;
						}
					};
				};
				const attachDragHandlersToCard = (card) => {
					if (!card) return;
					const onPointerDown = (ev) => {
						ev.preventDefault();
						ev.stopPropagation();
						if (!mapPickerMarker || !mapPickerDragOverlay) return;
						const projection = mapPickerDragOverlay.getProjection();
						if (!projection) return;
						mapPickerDragState = {
							pointerId: ev.pointerId,
							startX: ev.clientX,
							startY: ev.clientY,
							startLatLng: mapPickerMarker.getPosition(),
							projection
						};
						try { card.setPointerCapture(ev.pointerId); } catch (cardCaptureErr) { }
						card.style.cursor = 'grabbing';
						if (mapPickerInstance) {
							try { mapPickerInstance.setOptions({ draggable: false }); } catch (e) { }
						}
					};
					const onPointerMove = (ev) => {
						if (!mapPickerDragState || ev.pointerId !== mapPickerDragState.pointerId) return;
						ev.preventDefault();
						ev.stopPropagation();
						const { projection, startLatLng, startX, startY } = mapPickerDragState;
						if (!projection || !startLatLng) return;
						const startPixel = projection.fromLatLngToDivPixel(startLatLng);
						if (!startPixel) return;
						const dx = ev.clientX - startX;
						const dy = ev.clientY - startY;
						const newPixel = new google.maps.Point(startPixel.x + dx, startPixel.y + dy);
						const newLatLng = projection.fromDivPixelToLatLng(newPixel);
						if (newLatLng && mapPickerMarker) {
							mapPickerMarker.setPosition(newLatLng);
						}
					};
					const endDrag = (ev) => {
						if (!mapPickerDragState || (ev && ev.pointerId !== mapPickerDragState.pointerId)) return;
						ev && (ev.preventDefault(), ev.stopPropagation());
						try { ev && card.releasePointerCapture(ev.pointerId); } catch (cardReleaseErr) { }
						mapPickerDragState = null;
						card.style.cursor = 'grab';
						if (mapPickerInstance) {
							try { mapPickerInstance.setOptions({ draggable: true }); } catch (e) { }
						}
					};
					card.style.cursor = 'grab';
					card.addEventListener('pointerdown', onPointerDown);
					card.addEventListener('pointermove', onPointerMove);
					card.addEventListener('pointerup', endDrag);
					card.addEventListener('pointercancel', endDrag);
				};
				const ensureDragCardOverlay = () => {
					if (!window.google || !google.maps || !google.maps.OverlayView) return;
					if (mapPickerDragOverlay) {
						if (mapPickerDragOverlay.show) mapPickerDragOverlay.show();
						return;
					}
					class MapPickerDragOverlay extends google.maps.OverlayView {
						constructor(marker) {
							super();
							this.marker = marker;
							this.card = null;
							this.arrow = null;
						}
						onAdd() {
							this.card = document.createElement('div');
							this.card.className = 'myd-map-picker__drag-card';
							
							const title = document.createElement('div');
							title.className = 'myd-map-picker__drag-card-title';
							title.textContent = 'Você está aqui?';
							
							const subtitle = document.createElement('div');
							subtitle.className = 'myd-map-picker__drag-card-subtitle';
							subtitle.textContent = 'Ajuste a localização arrastando';
							
							this.card.appendChild(title);
							this.card.appendChild(subtitle);
							
							this.arrow = document.createElement('div');
							this.arrow.className = 'myd-map-picker__drag-card-arrow';
							this.card.appendChild(this.arrow);
							
							const panes = this.getPanes();
							panes && panes.floatPane && panes.floatPane.appendChild(this.card);
							mapPickerDragCardElement = this.card;
							attachDragHandlersToCard(this.card);
						}
						draw() {
							if (!this.card) return;
							const projection = this.getProjection();
							if (!projection) return;
							const position = this.marker ? this.marker.getPosition() : null;
							if (!position) return;
							const point = projection.fromLatLngToDivPixel(position);
							if (point) {
								this.card.style.left = `${point.x}px`;
								this.card.style.top = `${point.y}px`;
							}
						}
						onRemove() {
							if (this.card && this.card.parentNode) this.card.parentNode.removeChild(this.card);
							mapPickerDragCardElement = null;
							this.card = null;
						}
						show() {
							if (this.card) this.card.style.display = 'flex';
						}
						hide() {
							if (this.card) this.card.style.display = 'none';
						}
						update() {
							this.draw();
						}
					}
					mapPickerDragOverlay = new MapPickerDragOverlay(mapPickerMarker);
					mapPickerDragOverlay.setMap(mapPickerInstance);
				};
				const openMapPicker = (seedPlace) => {
					if (!window.google || !google.maps || !google.maps.Map) {
						if (window.Myd && window.Myd.notificationBar) window.Myd.notificationBar('error', 'Não foi possível exibir o mapa agora.');
						return Promise.resolve(null);
					}
					ensureMapPickerModal();
					let fallbackCenter = { lat: -14.235, lng: -51.9253 };
					try {
						if (typeof mydStoreInfo !== 'undefined' && mydStoreInfo.deliveryShipping && mydStoreInfo.deliveryShipping.options && mydStoreInfo.deliveryShipping.options.originAddress) {
							const origin = mydStoreInfo.deliveryShipping.options.originAddress;
							if (origin && origin.latitude && origin.longitude) {
								fallbackCenter = { lat: Number(origin.latitude) || -14.235, lng: Number(origin.longitude) || -51.9253 };
							}
						}
					} catch (err) { }
					const computed = ensureLatLng(seedPlace && seedPlace.geometry ? seedPlace.geometry.location : null);
					const center = (computed.lat || computed.lng) ? computed : fallbackCenter;
					if (!mapPickerInstance) {
						mapPickerInstance = new google.maps.Map(mapPickerMapContainer, {
							center,
							zoom: center.lat ? 17 : 5,
							mapTypeControl: false,
							streetViewControl: false,
							fullscreenControl: false,
							// Prevent points of interest and other icons from responding to clicks
							clickableIcons: false
						});
						mapPickerInstance.addListener('click', (event) => {
							if (mapPickerMarker && event && event.latLng) {
								mapPickerMarker.setPosition(event.latLng);
							}
						});
					} else {
						mapPickerInstance.setCenter(center);
						mapPickerInstance.setZoom(center.lat ? 17 : 5);
					}
					if (!mapPickerMarker) {
						mapPickerMarker = new google.maps.Marker({ draggable: true });
					}
					mapPickerMarker.setMap(mapPickerInstance);
					mapPickerMarker.setPosition(center);
					ensureDragCardOverlay();
					if (mapPickerDragOverlay && mapPickerDragOverlay.update) mapPickerDragOverlay.update();
					if (!mapPickerMarkerPositionListener && window.google && google.maps && google.maps.event) {
						mapPickerMarkerPositionListener = google.maps.event.addListener(mapPickerMarker, 'position_changed', () => {
							if (mapPickerDragOverlay && mapPickerDragOverlay.update) mapPickerDragOverlay.update();
						});
					}
					if (!mapPickerGeocoder) mapPickerGeocoder = new google.maps.Geocoder();
					mapPickerModal.style.display = 'flex';
					// Ensure map view is shown initially
					mapPickerMapView.style.display = 'block';
					mapPickerDetailsView.style.display = 'none';
					setTimeout(() => {
						try { google.maps.event.trigger(mapPickerInstance, 'resize'); } catch (resizeErr) { }
						mapPickerInstance.setCenter(center);
					}, 100);
					return new Promise((resolve) => {
						const close = () => {
							mapPickerModal.style.display = 'none';
							if (mapPickerDragOverlay && mapPickerDragOverlay.hide) mapPickerDragOverlay.hide();
							mapPickerDragState = null;
							if (mapPickerDragCardElement) mapPickerDragCardElement.style.cursor = 'grab';
							if (mapPickerInstance) {
								try { mapPickerInstance.setOptions({ draggable: true }); } catch (e) { }
							}
							// Reset views
							mapPickerMapView.style.display = 'block';
							mapPickerDetailsView.style.display = 'none';
						};
						mapPickerCancelBtn.onclick = () => { close(); resolve(null); };
						mapPickerConfirmBtn.onclick = () => {
							const position = mapPickerMarker.getPosition();
							if (!position) { close(); resolve(null); return; }
							mapPickerGeocoder.geocode({ location: position }, (results, status) => {
								if (status !== 'OK' || !results || !results.length) {
									if (window.Myd && window.Myd.notificationBar) window.Myd.notificationBar('error', 'Não foi possível validar essa localização.');
									return;
								}
								const selected = results.find((item) => hasNeighborhoodComponent(item.address_components)) || results[0];
								if (!hasNeighborhoodComponent(selected.address_components)) {
									if (window.Myd && window.Myd.notificationBar) window.Myd.notificationBar('error', 'Ajuste o marcador até encontrar o bairro.');
									return;
								}
								
								// Extract address components for display
								const comp = selected.address_components || [];
								const street_number = comp.find(c => c.types.includes('street_number'));
								const route = comp.find(c => c.types.includes('route'));
								const sublocality = comp.find(c => c.types.includes('sublocality_level_1') || c.types.includes('sublocality'));
								const cityComp = comp.find(c => c.types.includes('locality') || c.types.includes('administrative_area_level_2') || c.types.includes('postal_town'));
								const stateComp = comp.find(c => c.types.includes('administrative_area_level_1'));
								
								// Build address display
								let mainAddress = '';
								if (route) mainAddress = route.long_name;
								if (street_number) mainAddress += ', ' + street_number.long_name;
								
								let secondaryAddress = '';
								if (sublocality) secondaryAddress = sublocality.long_name;
								if (cityComp) secondaryAddress += (secondaryAddress ? ', ' : '') + cityComp.long_name;
								if (stateComp) secondaryAddress += ' - ' + stateComp.short_name;
								
								// Update details view
								const mainEl = mapPickerDetailsAddress.querySelector('.myd-map-picker__address-main');
								const secondaryEl = mapPickerDetailsAddress.querySelector('.myd-map-picker__address-secondary');
								if (mainEl) mainEl.textContent = mainAddress || selected.formatted_address;
								if (secondaryEl) secondaryEl.textContent = secondaryAddress;
								
								// Pre-fill number if available
								mapPickerDetailsNumber.value = street_number ? street_number.long_name : '';
								mapPickerDetailsComplement.value = '';
								mapPickerDetailsReference.value = '';
								
