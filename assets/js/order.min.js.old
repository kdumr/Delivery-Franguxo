						div.addEventListener('click', () => selectSuggestion(it));
						suggestionsContainer.appendChild(div);
					});
					suggestionsContainer.style.display = 'block';
					try { console.debug('myd: suggestionsContainer shown, children=', suggestionsContainer.children.length); } catch (e) { }
				};
				const hideSuggestions = () => { try { clearInterval(typingInterval); typingInterval = null; } catch (e) { } if (suggestionsContainer) { suggestionsContainer.style.display = 'none'; suggestionsContainer.innerHTML = ''; } };
				// When suggestion selected: fetch place details (geometry, address_components)
				const selectSuggestion = async (item) => {
					hideSuggestions();
					try { console.debug('myd: suggestion selected', item); } catch (e) { }
					// If server returned full details use them, else call Place Details endpoint
					let place = item;

					// helpers: show/hide a centered loading overlay while fetching details / opening map
					const showMapLoading = () => {
						let ol = document.getElementById('myd-map-loading-overlay');
						if (!ol) {
							ol = document.createElement('div');
							ol.id = 'myd-map-loading-overlay';
							ol.style.position = 'fixed';
							ol.style.inset = '0';
							ol.style.display = 'flex';
							ol.style.alignItems = 'center';
							ol.style.justifyContent = 'center';
							ol.style.background = 'rgba(0,0,0,0.45)';
							ol.style.zIndex = '10000';
							ol.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;">' +
								'<svg width="64" height="64" viewBox="0 0 50 50" aria-hidden="true">' +
								'<circle cx="25" cy="25" r="20" fill="none" stroke="#ffffff" stroke-width="5" stroke-linecap="round" stroke-dasharray="31.4 31.4">' +
								'<animateTransform attributeName="transform" type="rotate" from="0 25 25" to="360 25 25" dur="1s" repeatCount="indefinite"/>' +
								'</circle>' +
								'</svg>' +
								'</div>';
							document.body.appendChild(ol);
						} else {
							ol.style.display = 'flex';
						}
					};

					const hideMapLoading = () => {
						const ol = document.getElementById('myd-map-loading-overlay');
						if (ol && ol.parentNode) ol.parentNode.removeChild(ol);
					};
					if (!place.geometry || !place.address_components) {
						// call Place Details
						try {
							// show loading while fetching place details
							showMapLoading();
							// Use server-side proxy to avoid exposing API key and CORS issues
							const placeDetailsUrl = `/wp-json/my-delivery/v1/places/details?place_id=${encodeURIComponent(item.place_id)}&fields=formatted_address,geometry,address_component,address_components`;
							const res = await fetch(placeDetailsUrl, { credentials: 'same-origin' });
							if (!res.ok) throw new Error('place-details-failed');
							const text = await res.text();
							let data = null;
							try { data = JSON.parse(text); } catch (parseErr) {
								// try to recover JSON from noisy response (strip leading warnings/html)
								try {
									const first = text.indexOf('{');
									const last = text.lastIndexOf('}');
									if (first !== -1 && last !== -1 && last > first) {
										const substr = text.substring(first, last + 1);
										data = JSON.parse(substr);
									}
								} catch (e2) {
									try { console.debug('myd: place details raw response (parse failed):', text); } catch (e3) { }
									data = null;
								}
							}
							if (data && data.result) place = data.result; else throw new Error('no-result');
							// fetch finished: hide the loading overlay now (we only wanted it during the request)
							try { hideMapLoading(); } catch (_e) { }
						} catch (err) {
							// hide loading (fetch failed or no-result)
							try { hideMapLoading(); } catch (_e) { }
							// Fallback: try to initialize original widget if available (CORS or API key restrictions may block REST)
							try { const widget = new google.maps.places.Autocomplete(input, { fields: ["formatted_address", "geometry", "address_components"], types: ["address"] }); widget.addListener('place_changed', () => { const e = widget.getPlace(); if (e && e.geometry) { selectSuggestion(e); } }); input.focus(); } catch (e) { }
							return;
						}
					}
					// open map picker (no loading overlay here; it was removed after fetch)
					const confirmedPlace = await openMapPicker(place);
					if (!confirmedPlace) return;
					place.formatted_address = confirmedPlace.formatted_address || place.formatted_address;
					place.address_components = confirmedPlace.address_components || place.address_components;
					if (!place.geometry) place.geometry = {};
					place.geometry.location = confirmedPlace.geometry && confirmedPlace.geometry.location ? confirmedPlace.geometry.location : place.geometry.location;
					if (confirmedPlace.place_id) place.place_id = confirmedPlace.place_id;
					// Store extra fields from details popup
					const confirmedStreetNumber = confirmedPlace.streetNumber || '';
					const confirmedComplement = confirmedPlace.complement || '';
					const confirmedReference = confirmedPlace.reference || '';
					// Now we have place with geometry and address_components
					const wrapper = document.getElementById("myd-autocomplete-wrapper");
					wrapper && (wrapper.style.display = "none");
					const extra = document.getElementById("myd-per-distance-address-extra");
					// per-distance uses a hidden field 'input-delivery-street-number' populated from autocomplete
					const numberEl = document.getElementById("input-delivery-street-number") || document.getElementById("input-delivery-address-number");
					if (extra) { extra.style.display = "block"; }
					if (numberEl) {
						// keep it required logically (hidden input) unless no-number checkbox is set
						numberEl.setAttribute("required", "required");
						numberEl.addEventListener('paste', (ev) => { ev.preventDefault(); });
						numberEl.addEventListener('drop', (ev) => { ev.preventDefault(); });
						numberEl.addEventListener('contextmenu', (ev) => { ev.preventDefault(); });
					}
