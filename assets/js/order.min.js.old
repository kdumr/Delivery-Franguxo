						clearTimeout(debounceTimer);
						debounceTimer = setTimeout(() => fn.apply(this, args), delay);
					}
				};
				// Build suggestions UI
				const showSuggestions = (items) => {
					try { console.debug('myd: showSuggestions called, items=', items); } catch (e) { }
					if (!suggestionsContainer) return;
					// stop typing indicator if running
					try { clearInterval(typingInterval); typingInterval = null; } catch (e) { }
					if (!items || items.length === 0) { suggestionsContainer.style.display = 'none'; suggestionsContainer.innerHTML = ''; return; }
					suggestionsContainer.innerHTML = '';
					items.forEach((it, idx) => {
						const div = document.createElement('div');
						div.className = 'myd-autocomplete-suggestion';
						div.style.padding = '8px 10px';
						div.style.cursor = 'pointer';
						div.style.borderBottom = '1px solid rgba(0,0,0,0.04)';
						div.dataset.placeId = it.place_id || '';

						// left icon (pin)
						const iconWrap = document.createElement('div');
						iconWrap.style.flex = '0 0 36px';
						iconWrap.style.display = 'flex';
						iconWrap.style.alignItems = 'center';
						iconWrap.style.justifyContent = 'center';
						iconWrap.style.marginRight = '8px';

						const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
						svg.setAttribute('width', '30');
						svg.setAttribute('height', '30');
						svg.setAttribute('viewBox', '0 0 24 24');
						svg.setAttribute('aria-hidden', 'true');
						svg.innerHTML = '<path fill="currentColor" d="M12 2C8.686 2 6 4.686 6 8c0 4.5 6 12 6 12s6-7.5 6-12c0-3.314-2.686-6-6-6zm0 8.5A2.5 2.5 0 1 1 12 5.5a2.5 2.5 0 0 1 0 5z"/>';
						svg.style.color = '#ffae00';
						iconWrap.appendChild(svg);

						// content wrapper (lines)
						const content = document.createElement('div');
						content.style.display = 'flex';
						content.style.flexDirection = 'column';
						content.style.minWidth = '0';

						// Line 1: street (main_text) only from API (do not append typed number)
						const line1 = document.createElement('div');
						line1.className = 'myd-autocomplete-suggestion-line1';
						line1.style.fontWeight = '600';
						line1.style.whiteSpace = 'normal';
						line1.style.wordBreak = 'break-word';
						let mainText = (it.structured_formatting && it.structured_formatting.main_text) ? it.structured_formatting.main_text : (it.main_text || it.description || '');
						const formattedMain = breakTextAtWhitespace(mainText, 40);
						line1.innerText = formattedMain.head;

						// Line 2: secondary text (neighborhood, city - state, country)
						const line2 = document.createElement('div');
						line2.className = 'myd-autocomplete-suggestion-line2';
						line2.style.fontSize = '12px';
						line2.style.color = '#666';
						line2.style.marginTop = '2px';
						let secondary = (it.structured_formatting && it.structured_formatting.secondary_text) ? it.structured_formatting.secondary_text : '';
						if (!secondary && it.terms && it.terms.length > 1) {
							const parts = it.terms.map(t => t.value);
							parts.shift();
							secondary = parts.join(', ');
						}
						line2.innerText = secondary;

						content.appendChild(line1);
						if (formattedMain.tail) {
							const tailLine = document.createElement('div');
							tailLine.className = 'myd-autocomplete-suggestion-line1-tail';
							tailLine.style.fontWeight = '600';
							tailLine.style.whiteSpace = 'normal';
							tailLine.style.wordBreak = 'break-word';
							tailLine.innerText = formattedMain.tail;
