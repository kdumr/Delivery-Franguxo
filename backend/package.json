{
  "name": "myd-push-server",
  "version": "1.0.0",
  "description": "Secure push server for MyDelivery using Socket.IO",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "generate-cert": "openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes -subj \"/C=US/ST=State/L=City/O=Organization/CN=localhost\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.2",
    "mysql2": "^3.7.0"
  }
}