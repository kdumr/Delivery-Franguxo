			<div class="fdm-orders-full">
				<div id="myd-welcome-cover" class="myd-welcome-cover" aria-hidden="false">
					<div class="myd-welcome-title-row">👋 Olá, <?php echo esc_html($__myd_user_name); ?></div>
					<div class="myd-welcome-grid">

						<div class="myd-skel myd-skel-mid">
								<div class="myd-schedule-card">
								<div class="myd-font-600" style="color:#2c2c2c;margin-bottom:8px;">Horário de funcionamento</div>
								<div class="myd-flex myd-gap-8" style="margin-bottom:12px;color:#5a5a5a;">
									<div class="myd-day-label" data-day="today">Hoje</div>
									<div class="myd-day-label" data-day="tomorrow">Amanhã</div>
